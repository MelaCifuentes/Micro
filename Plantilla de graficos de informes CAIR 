        "    plt.scatter(operaciones[i], morosidad[i], color=color, s=120)\n",
        "\n",
        "    # Etiqueta en morado\n",
        "    plt.text(operaciones[i], morosidad[i] + 0.3,\n",
        "             provincias[i],\n",
        "             fontsize=12,\n",
